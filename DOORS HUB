local AntiCheat = {
    Enabled = true,
    Settings = {
        MaxSpeed = 22,
        SmoothTransition = true,
        TransitionSpeed = 0.15,
        RandomVariation = true,
        VariationRange = 0.3,
        PulseEffect = true,
        PulseInterval = 2,
        HumanLikeMovement = true,
        DetectionAvoidance = true,
        SafetyMargin = 1.5,
        AdaptiveSpeed = true,
        StealthMode = true
    },
    Data = {
        BaseSpeed = 16,
        CurrentSpeed = 16,
        TargetSpeed = 16,
        LastUpdate = tick(),
        LastPulse = tick(),
        DetectionLevel = 0,
        IsRunning = false,
        SpeedHistory = {},
        MaxHistorySize = 50
    }
}

function AntiCheat:CalculateSafeSpeed(desiredSpeed)
    local safeSpeed = math.min(desiredSpeed, self.Settings.MaxSpeed)
    
    if self.Settings.RandomVariation then
        local variation = (math.random() - 0.5) * 2 * self.Settings.VariationRange
        safeSpeed = safeSpeed + variation
    end
    
    if self.Settings.PulseEffect then
        if tick() - self.Data.LastPulse > self.Settings.PulseInterval then
            local pulse = math.sin(tick() * 2) * 0.5
            safeSpeed = safeSpeed + pulse
            self.Data.LastPulse = tick()
        end
    end
    
    if self.Settings.HumanLikeMovement then
        local humanFactor = math.sin(tick() * 3.5) * 0.2 + math.cos(tick() * 1.7) * 0.15
        safeSpeed = safeSpeed + humanFactor
    end
    
    if self.Settings.AdaptiveSpeed then
        local avgSpeed = self:GetAverageSpeed()
        if avgSpeed > 0 then
            local adaptiveFactor = math.clamp((safeSpeed - avgSpeed) / avgSpeed, -0.1, 0.1)
            safeSpeed = safeSpeed - adaptiveFactor
        end
    end
    
    if self.Settings.StealthMode then
        safeSpeed = math.min(safeSpeed, self.Settings.MaxSpeed - self.Settings.SafetyMargin)
    end
    
    return math.clamp(safeSpeed, self.Data.BaseSpeed, self.Settings.MaxSpeed)
end

function AntiCheat:GetAverageSpeed()
    if #self.Data.SpeedHistory == 0 then return 0 end
    
    local sum = 0
    for _, speed in ipairs(self.Data.SpeedHistory) do
        sum = sum + speed
    end
    
    return sum / #self.Data.SpeedHistory
end

function AntiCheat:AddToHistory(speed)
    table.insert(self.Data.SpeedHistory, speed)
    
    if #self.Data.SpeedHistory > self.Settings.MaxHistorySize then
        table.remove(self.Data.SpeedHistory, 1)
    end
end

function AntiCheat:SmoothSpeed(current, target, delta)
    if not self.Settings.SmoothTransition then
        return target
    end
    
    local difference = target - current
    local change = difference * self.Settings.TransitionSpeed * (delta * 60)
    
    return current + change
end

function AntiCheat:UpdateDetectionLevel()
    local avgSpeed = self:GetAverageSpeed()
    
    if avgSpeed > self.Settings.MaxSpeed * 0.9 then
        self.Data.DetectionLevel = math.min(self.Data.DetectionLevel + 0.1, 1)
    else
        self.Data.DetectionLevel = math.max(self.Data.DetectionLevel - 0.05, 0)
    end
    
    if self.Settings.DetectionAvoidance and self.Data.DetectionLevel > 0.7 then
        self.Settings.MaxSpeed = math.max(self.Settings.MaxSpeed - 0.5, 18)
        
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "⚠️ АНТИЧИТ";
            Text = "Обнаружена высокая активность! Снижение скорости...";
            Duration = 3;
        })
    elseif self.Data.DetectionLevel < 0.2 then
        self.Settings.MaxSpeed = math.min(self.Settings.MaxSpeed + 0.1, 22)
    end
end

function AntiCheat:Update()
    if not self.Enabled then return end
    
    local character = LocalPlayer.Character
    if not character then return end
    
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    
    local delta = tick() - self.Data.LastUpdate
    self.Data.LastUpdate = tick()
    
    local desiredSpeed = self.Data.TargetSpeed
    local safeSpeed = self:CalculateSafeSpeed(desiredSpeed)
    
    self.Data.CurrentSpeed = self:SmoothSpeed(self.Data.CurrentSpeed, safeSpeed, delta)
    
    if humanoid.WalkSpeed ~= self.Data.CurrentSpeed then
        humanoid.WalkSpeed = self.Data.CurrentSpeed
    end
    
    self:AddToHistory(self.Data.CurrentSpeed)
    
    if tick() % 1 < delta then
        self:UpdateDetectionLevel()
    end
end

function AntiCheat:SetTargetSpeed(speed)
    self.Data.TargetSpeed = speed
    self.Data.IsRunning = speed > self.Data.BaseSpeed
end

function AntiCheat:Reset()
    self.Data.CurrentSpeed = self.Data.BaseSpeed
    self.Data.TargetSpeed = self.Data.BaseSpeed
    self.Data.SpeedHistory = {}
    self.Data.DetectionLevel = 0
    self.Data.IsRunning = false
    self.Settings.MaxSpeed = 22
    
    local character = LocalPlayer.Character
    if character then
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        if humanoid then
            humanoid.WalkSpeed = self.Data.BaseSpeed
        end
    end
end

