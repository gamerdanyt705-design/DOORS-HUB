local SpeedSystem = {}
SpeedSystem.Connection = nil

function SpeedSystem:Enable()
    pcall(function()
        if self.Connection then
            self.Connection:Disconnect()
            self.Connection = nil
        end
        
        if Config.Speed.UseAntiCheat then
            AntiCheat:SetTargetSpeed(Config.Speed.Value)
            AntiCheat.Enabled = true
            
            game:GetService("StarterGui"):SetCore("SendNotification", {
                Title = "🛡️ АНТИЧИТ СКОРОСТИ";
                Text = "✅ Защита активирована! Безопасная скорость установлена.";
                Duration = 4;
            })
        end
        
        self.Connection = RunService.Heartbeat:Connect(function()
            if not Config.Speed.Enabled then return end
            
            if Config.Speed.UseAntiCheat then
                AntiCheat:Update()
            else
                local character = LocalPlayer.Character
                if not character then return end
                
                local humanoid = character:FindFirstChildOfClass("Humanoid")
                if not humanoid then return end
                
                if humanoid.WalkSpeed ~= Config.Speed.Value then
                    humanoid.WalkSpeed = Config.Speed.Value
                end
            end
        end)
    end)
end

function SpeedSystem:Disable()
    pcall(function()
        if self.Connection then
            self.Connection:Disconnect()
            self.Connection = nil
        end
        
        AntiCheat.Enabled = false
        AntiCheat:Reset()
        
        local character = LocalPlayer.Character
        if character then
            local humanoid = character:FindFirstChildOfClass("Humanoid")
            if humanoid then
                humanoid.WalkSpeed = 16
            end
        end
    end)
end

function SpeedSystem:UpdateSpeed(value)
    Config.Speed.Value = value
    
    if Config.Speed.UseAntiCheat then
        AntiCheat:SetTargetSpeed(value)
    end
end

